{
  "name": "astrbot-dashboard",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "author": "CodedThemes",
  "scripts": {
    "dev": "node scripts/subset-mdi-font.mjs && vite --host",
    "build:t2i-shiki-runtime": "node scripts/build-t2i-shiki-runtime.mjs",
    "build": "tsc -p tsconfig.vite-config.json --noEmit && vue-tsc --noEmit && vite build && node scripts/write-dashboard-version.mjs",
    "build-stage": "tsc -p tsconfig.vite-config.json --noEmit && vue-tsc --noEmit && vite build --base=/vue/free/stage/ && node scripts/write-dashboard-version.mjs",
    "build-prod": "tsc -p tsconfig.vite-config.json --noEmit && vue-tsc --noEmit && vite build --base=/vue/free/ && node scripts/write-dashboard-version.mjs",
    "preview": "vite preview --port 5050",
    "test": "vitest run --config vitest.config.ts",
    "test:smoke": "vitest run --config vitest.config.ts",
    "generate:api": "node -e \"const fs=require('node:fs'); fs.rmSync('src/api/generated/openapi-v1', { recursive: true, force: true }); fs.rmSync('src/api/generated/openapi-v1.ts', { force: true });\" && openapi-ts -i ../openspec/openapi-v1.yaml -o src/api/generated/openapi-v1 -c @hey-api/client-axios",
    "generate:docs:openapi": "uv run python ../docs/scripts/update_openapi_json.py",
    "typecheck": "tsc -p tsconfig.vite-config.json --noEmit && vue-tsc --noEmit",
    "lint": "eslint . --fix"
  },
  "dependencies": {
    "@guolao/vue-monaco-editor": "1.6.0",
    "@hey-api/client-axios": "0.9.1",
    "@tiptap/starter-kit": "3.27.1",
    "@tiptap/vue-3": "3.27.1",
    "apexcharts": "5.15.2",
    "axios": "1.18.1",
    "axios-mock-adapter": "2.1.0",
    "chance": "1.1.13",
    "date-fns": "4.4.0",
    "dompurify": "3.4.11",
    "event-source-polyfill": "1.0.31",
    "highlight.js": "11.11.1",
    "katex": "0.17.0",
    "lodash": "4.18.1",
    "markdown-it": "14.2.0",
    "markstream-vue": "1.0.4",
    "mermaid": "11.16.0",
    "monaco-editor": "0.55.1",
    "pinia": "3.0.4",
    "pinyin-pro": "3.28.1",
    "qrcode": "1.5.4",
    "shiki": "4.3.0",
    "stream-markdown": "0.0.16",
    "vee-validate": "4.15.1",
    "vite-plugin-vuetify": "2.1.3",
    "vue": "3.5.39",
    "vue-i18n": "11.4.6",
    "vue-router": "5.1.0",
    "vue3-apexcharts": "1.11.1",
    "vue3-print-nb": "0.1.4",
    "vuetify": "4.1.2",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@hey-api/openapi-ts": "0.99.0",
    "@mdi/font": "7.4.47",
    "@types/chance": "1.1.8",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "26.0.1",
    "@vitejs/plugin-vue": "6.0.7",
    "@vue/test-utils": "2.4.11",
    "@vue/tsconfig": "0.9.1",
    "eslint": "10.6.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.1",
    "sass": "1.101.0",
    "subset-font": "2.5.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vite": "8.1.0",
    "vite-plugin-webfont-dl": "3.12.0",
    "vitest": "4.1.9",
    "vue-eslint-parser": "10.4.1",
    "vue-tsc": "3.3.5"
  }
}
